## KPI Card Pattern

```tsx
interface KPICardProps {
    label: string
    value: string | number
    change?: { value: number; direction: 'up' | 'down'; good: boolean }
    icon?: React.ReactNode
}

// Keep cards minimal — label, big number, delta
export function KPICard({ label, value, change }: KPICardProps) {
    return (
        <div className="rounded-xl border border-gray-100 bg-white p-5 space-y-2">
            <p className="text-sm text-gray-500 font-medium">{label}</p>
            <p className="text-3xl font-semibold tracking-tight">{value}</p>
            {change && (
                <p className={cn("text-sm font-medium", change.good ? "text-emerald-600" : "text-rose-600")}>
                    {change.direction === 'up' ? '↑' : '↓'} {Math.abs(change.value)}%
                </p>
            )}
        </div>
    )
}
```

