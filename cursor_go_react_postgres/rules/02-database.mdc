## Repository Pattern

```go
type MetricsRepository interface {
    FindHourlyAverages(ctx context.Context, sensorID uuid.UUID, from, to time.Time) ([]HourlyAverage, error)
}

type pgMetricsRepo struct{ pool *pgxpool.Pool }

func (r *pgMetricsRepo) FindHourlyAverages(ctx context.Context, sensorID uuid.UUID, from, to time.Time) ([]HourlyAverage, error) {
    const q = `
        SELECT date_trunc('hour', recorded_at) AS bucket,
               avg(value)::float8
        FROM metrics
        WHERE sensor_id = $1
          AND recorded_at BETWEEN $2 AND $3
        GROUP BY 1
        ORDER BY 1`

    rows, err := r.pool.Query(ctx, q, sensorID, from, to)
    if err != nil {
        return nil, fmt.Errorf("FindHourlyAverages: %w", err)
    }
    defer rows.Close()

    return pgx.CollectRows(rows, pgx.RowToStructByName[HourlyAverage])
}
```

