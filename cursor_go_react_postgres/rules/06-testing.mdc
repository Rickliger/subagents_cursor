## React Testing Strategy

### Hook tests with React Query

```tsx
// features/revenue/useRevenue.test.ts
import { renderHook, waitFor } from '@testing-library/react'
import { createWrapper } from '@/test/utils'  // QueryClient wrapper
import { useRevenue } from './useRevenue'

it('fetches revenue metrics', async () => {
    server.use(
        http.get('/v1/revenue', () => HttpResponse.json({ data: mockRevenue }))
    )

    const { result } = renderHook(() => useRevenue({ period: '7d' }), {
        wrapper: createWrapper(),
    })

    await waitFor(() => expect(result.current.isSuccess).toBe(true))
    expect(result.current.data).toEqual(mockRevenue)
})
```

Use **MSW (Mock Service Worker)** for API mocking — test at the network level, not by mocking modules.

### Component tests — test behavior, not structure

```tsx
// features/revenue/RevenueChart.test.tsx
it('shows skeleton while loading', () => {
    server.use(http.get('/v1/revenue', () => delay('infinite')))

    render(<RevenueChart filter={{ period: '7d' }} />, { wrapper: createWrapper() })

    expect(screen.getByTestId('chart-skeleton')).toBeInTheDocument()
})

it('shows error state on API failure', async () => {
    server.use(http.get('/v1/revenue', () => HttpResponse.json({}, { status: 500 })))

    render(<RevenueChart filter={{ period: '7d' }} />, { wrapper: createWrapper() })

    await waitFor(() => {
        expect(screen.getByText(/something went wrong/i)).toBeInTheDocument()
    })
})

it('renders chart data on success', async () => {
    server.use(http.get('/v1/revenue', () => HttpResponse.json({ data: mockRevenue })))

    render(<RevenueChart filter={{ period: '7d' }} />, { wrapper: createWrapper() })

    await waitFor(() => {
        expect(screen.getByRole('img', { name: /revenue chart/i })).toBeInTheDocument()
    })
})
```

**Never test**: implementation details (internal state, private methods), Recharts internals, Tailwind class names.

